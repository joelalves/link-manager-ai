# Copy to .env (same folder as docker-compose.yml) before running Compose.
# Compose reads this file for ${VAR} substitution, and the backend service
# loads it via env_file.

# --- Postgres (database service) ---
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=linkmanager

# --- Backend ---
# Host is the compose service name "database", not localhost.
DATABASE_URL=postgresql://appuser:apppassword@database:5432/linkmanager
JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gpt-4.1-mini
AI_BASE_URL=https://api.openai.com/v1
AI_MAX_CONTENT_CHARS=6000
AI_TIMEOUT_SECONDS=30
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
# Leave empty to auto-detect API URL from the browser hostname (recommended for
# deployments accessible from multiple addresses). Set explicitly to override.
VITE_API_URL=
# Extra CORS origins beyond FRONTEND_URL, comma-separated. Add your local IP
# and/or external domain when deploying on a home server.
CORS_ORIGINS=
RATE_LIMIT=200/minute

# Default user created on first DB init (change before first run)
DEFAULT_USERNAME=admin
DEFAULT_EMAIL=admin@localhost
DEFAULT_PASSWORD=changeme123

# --- Database ---
# For Docker Compose (Postgres):
DATABASE_URL=postgresql://appuser:apppassword@database:5432/linkmanager
# For local dev without Postgres, use SQLite instead:
# DATABASE_URL=sqlite:///./linkmanager.db

# --- Auth ---
JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- AI (OpenAI-compatible API) ---
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gpt-4.1-mini
AI_BASE_URL=https://api.openai.com/v1
AI_MAX_CONTENT_CHARS=6000
AI_TIMEOUT_SECONDS=30

# --- App ---
BACKEND_PORT=5000
FRONTEND_URL=http://localhost:3000
RATE_LIMIT=200/minute
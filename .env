# --- Database ---
# For Docker Compose (Postgres):
DATABASE_URL=postgresql://appuser:apppassword@database:5432/linkmanager
# For local dev without Postgres, use SQLite instead:
# DATABASE_URL=sqlite:///./linkmanager.db

# --- Auth ---
JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- AI (OpenAI-compatible API) ---
AI_API_KEY=AI_KEY_GOES_HERE
AI_MODEL=gpt-4.1-mini
AI_BASE_URL=https://api.openai.com/v1
AI_MAX_CONTENT_CHARS=6000
AI_TIMEOUT_SECONDS=30

# --- App ---
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
# Leave VITE_API_URL empty so the frontend auto-detects the backend from the
# browser's hostname (works for both local IP and external domain without rebuild).
VITE_API_URL=
# Add any extra origins that need CORS access (comma-separated).
CORS_ORIGINS=
RATE_LIMIT=200/minute

# Default user created on first DB init (change before first run)
DEFAULT_USERNAME=admin
DEFAULT_EMAIL=admin@localhost
DEFAULT_PASSWORD=changeme123